{
  "name": "@captureradar/api-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CaptureRadar Node API — Hono on Node.js, Postgres (Drizzle), Redis, BullMQ.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "queue:dashboard": "tsx src/queues/dashboard.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@bull-board/api": "^6.5.0",
    "@bull-board/hono": "^6.5.0",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.4.0",
    "bullmq": "^5.28.0",
    "drizzle-orm": "^0.36.0",
    "drizzle-zod": "^0.5.1",
    "hono": "^4.6.10",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
