# =============================================================================
# CaptureRadar API — environment configuration
# Copy to .env (gitignored). Load on the Oracle VM via systemd EnvironmentFile.
# =============================================================================

# ── Server ──
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── Postgres (self-hosted on the VM; Drizzle reads via node-postgres) ──
# When the API runs on the same VM as Postgres, use the unix socket path or
# 127.0.0.1. The local install script provisions a 'captureradar' DB and
# 'captureradar' role; password is generated and stored in /etc/captureradar/db.pass
DATABASE_URL=postgres://captureradar:CHANGEME@127.0.0.1:5432/captureradar
PG_POOL_MAX=10

# ── Redis (BullMQ + cache) ──
REDIS_URL=redis://127.0.0.1:6379

# ── Auth ──
# Sessions are issued by the Cloudflare Worker (workers/api) and stored in
# the same Postgres app_session table this API reads. We don't need OAuth
# secrets here — only the cookie name + base origin.
SESSION_COOKIE=awards_session
PUBLIC_BASE_URL=https://awards-dashboard.pages.dev

# Comma-separated list of allowed origins for CORS (the dashboard, plus the
# Workers auth proxy origin if it ever calls back).
CORS_ORIGINS=https://awards-dashboard.pages.dev,http://localhost:5173

# Bootstrap admin email — first user with this email is auto-promoted to admin.
# Mirrors workers/api/src/auth/routes.ts ADMIN_BOOTSTRAP_EMAIL.
ADMIN_BOOTSTRAP_EMAIL=algocrat@gmail.com

# ── Cloudflare Workers AI (free tier — 10K neurons/day) ──
# Used for: opportunity summaries, value estimates, embeddings, chat responses.
# Get from: https://dash.cloudflare.com/profile/api-tokens (Workers AI scope).
CF_ACCOUNT_ID=
CF_WORKERS_AI_TOKEN=
# Default models — flip to bigger ones if quota allows.
CF_AI_GENERATION_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast
CF_AI_EMBEDDING_MODEL=@cf/baai/bge-base-en-v1.5

# ── Anthropic (optional — Phase 1 leaves blank, used when budget unlocks) ──
ANTHROPIC_API_KEY=

# ── Email (Resend free tier — 3K/mo) ──
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@captureradar.app

# ── External APIs ──
SAM_GOV_API_KEY=
INGEST_TOKEN=

# ── Storage (Cloudflare R2 free tier — 10GB) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=captureradar-documents
R2_PUBLIC_URL=https://documents.captureradar.app

# ── Operational toggles ──
# When set, ingestion jobs use seeded data instead of hitting live APIs.
# Useful for demo dataset or when an upstream is rate-limiting.
INGESTION_MODE=seed
# Daily cap on Workers AI inference calls (safety guard against burning quota).
WORKERS_AI_DAILY_BUDGET=8000
