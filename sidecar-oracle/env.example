# ─── Required ───────────────────────────────────────────────────────────────
# Your Cloudflare api-worker URL (no trailing slash).
API_BASE=https://api-worker.algocrat.workers.dev

# Shared secret for /import/awards + /admin/sidecar/views. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   openssl rand -hex 32                           # Git Bash / Linux / macOS
#   python -c "import secrets; print(secrets.token_hex(32))"
# Then `wrangler secret put INGEST_TOKEN` in workers/api/ with the same value.
INGEST_TOKEN=REPLACE_WITH_A_64_HEX_CHAR_RANDOM_STRING

# ─── Per-view ingestion controls ────────────────────────────────────────────
# This sidecar reads enabled views from the dashboard's Admin → Views, and
# ingests each one independently. There are no agency / keyword / lookback
# env vars anymore — every view defines its own scope through the UI.

# Maximum USAspending pages fetched per view per run. 100 records/page.
# 25 = up to 2,500 records per view per night.
MAX_PAGES_PER_VIEW=25

# Used when a view doesn't set its own lookback_months filter. 24 = 2 years.
FALLBACK_LOOKBACK_MO=24

# Set to a single view_id to ingest just one view (useful for ad-hoc tests).
# ONLY_VIEW=
