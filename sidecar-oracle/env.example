# ─── Required ───────────────────────────────────────────────────────────────
# Your Cloudflare api-worker URL (no trailing slash).
API_BASE=https://api-worker.algocrat.workers.dev

# Shared secret for /import/awards. Generate one with any of:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   openssl rand -hex 32                           # Git Bash / Linux / macOS
#   python -c "import secrets; print(secrets.token_hex(32))"
# Then `wrangler secret put INGEST_TOKEN` in workers/api/ with the same value.
INGEST_TOKEN=REPLACE_WITH_A_64_HEX_CHAR_RANDOM_STRING

# ─── Date window ────────────────────────────────────────────────────────────
# Leave blank to default to "last 90 days → today".
# SINCE=2024-01-01
# UNTIL=2024-12-31

# ─── Scope filters (all optional; blank = no filter in that dimension) ─────
AGENCIES=Department of Health and Human Services
# SUBTIER_AGENCIES=Centers for Disease Control and Prevention
# KEYWORDS=HIV,tuberculosis,NCHHSTP
# NAICS_CODES=541511,541712
# PSC_CODES=R408,Q301
# RECIPIENT=Lantana
MIN_VALUE=4000000
# MAX_VALUE=

# ─── Safety cap ─────────────────────────────────────────────────────────────
# 100 records per page. 10 pages = up to 1000 records per run.
MAX_PAGES=10

# ─── Award type codes ───────────────────────────────────────────────────────
# Default: A,B,C,D (procurement contracts). Use "02,03,04,05" for grants.
# AWARD_TYPES=A,B,C,D
